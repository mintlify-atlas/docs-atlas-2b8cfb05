  "keyFeatures": [
    "Circuit breaker with closed/open/half-open states and configurable thresholds",
    "Token bucket rate limiting with per-endpoint configuration and adaptive behavior",
    "PCI-compliant logging with automatic sanitization of sensitive data",
    "Smart retry logic with exponential backoff, jitter, and Retry-After header support",
    "Request deduplication to prevent duplicate side effects from double-clicks or race conditions",
    "Comprehensive telemetry events via Elixir's :telemetry library",
    "Multi-adapter support: Finch (default), Req, and Tesla",
    "Pre-configured profiles for payment processing, high-volume APIs, and microservices",
    "Test mode with adapter-agnostic mocking via HTTPower.Test",
    "Clean error handling — never raises exceptions, always returns result tuples"
  ],
  "publicApiSurface": [
